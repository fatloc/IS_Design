@startuml
title Chuc nang Lap yeu cau thue

hide footbox
autonumber 1
skinparam shadowing false
skinparam sequence {
  ArrowColor #8A2E5D
  LifeLineBorderColor #666666
  LifeLineBackgroundColor #FFFFFF
  ParticipantBorderColor #666666
  ParticipantBackgroundColor #F6F3C9
  ParticipantFontColor #222222
  ActivationBorderColor #8A2E5D
  ActivationBackgroundColor #F9EAF2
}
skinparam ActorBorderColor #8A2E5D
skinparam ActorBackgroundColor #FFFFFF

actor ": Nhan vien Sale" as Sale
boundary ": MHYeuCauThue" as UI_Main
boundary ": MHChiTietYeuCauThue" as UI_Detail
boundary ": MHLapYeuCauMoi" as UI_Create

control ": YeuCauDangKy" as S_Request
control ": KhachHang" as S_Customer
control ": LichXemPhong" as S_Appointment

database ": YeuCauDangKyDB" as DB_Request
database ": KhachHangDB" as DB_Customer
database ": LichXemPhongDB" as DB_Appointment

== Tai danh sach yeu cau va thong ke trang thai ==
Sale -> UI_Main: loadRequests(params)
activate Sale
activate UI_Main
UI_Main -> S_Request: getRequests(page, size, nhanVienPhuTrach, trangThaiYeuCau)
activate S_Request
alt Co bo loc nhan vien va trang thai
  S_Request -> DB_Request: findByNhanVienPhuTrachAndTrangThaiYeuCau(...)
  activate DB_Request
  DB_Request --> S_Request: findByNhanVienPhuTrachAndTrangThaiYeuCau(...): Page<YeuCauDangKy>
  deactivate DB_Request
else Chi co bo loc nhan vien
  S_Request -> DB_Request: findByNhanVienPhuTrach(...)
  activate DB_Request
  DB_Request --> S_Request: findByNhanVienPhuTrach(...): Page<YeuCauDangKy>
  deactivate DB_Request
else Chi co bo loc trang thai
  S_Request -> DB_Request: findByTrangThaiYeuCau(...)
  activate DB_Request
  DB_Request --> S_Request: findByTrangThaiYeuCau(...): Page<YeuCauDangKy>
  deactivate DB_Request
else Khong co bo loc
  S_Request -> DB_Request: findAll(pageable)
  activate DB_Request
  DB_Request --> S_Request: findAll(...): Page<YeuCauDangKy>
  deactivate DB_Request
end
S_Request --> UI_Main: getRequests(...): ApiListResponse<YeuCauDangKy>
deactivate S_Request

UI_Main -> S_Request: getRequestStatusCounts()
activate S_Request
S_Request -> DB_Request: countByStatus()
activate DB_Request
DB_Request --> S_Request: countByStatus(): List<Object[]>
deactivate DB_Request
S_Request --> UI_Main: getRequestStatusCounts(...): Map<String, Long>
deactivate S_Request

UI_Main --> Sale: render requestTable + statusCards + pagination
deactivate UI_Main
deactivate Sale

== Xem chi tiet yeu cau ==
Sale -> UI_Main: handleOpenRequest(maYeuCau)
activate Sale
activate UI_Main
UI_Main -> S_Request: getRequestById(maYeuCau)
activate S_Request
S_Request -> DB_Request: findById(maYeuCau)
activate DB_Request
DB_Request --> S_Request: findById(...): Optional<YeuCauDangKy>
deactivate DB_Request
S_Request --> UI_Main: getRequestById(...): YeuCauDangKy
deactivate S_Request

UI_Main -> UI_Detail: open(yeuCau)
activate UI_Detail
UI_Detail -> S_Appointment: getAppointmentByRequest(maYeuCau)
activate S_Appointment
S_Appointment -> DB_Appointment: findByMaYeuCau(maYeuCau)
activate DB_Appointment
DB_Appointment --> S_Appointment: findByMaYeuCau(...): Optional<LichXemPhong>
deactivate DB_Appointment
S_Appointment --> UI_Detail: getAppointmentByRequest(...): LichXemPhong
deactivate S_Appointment
UI_Detail --> UI_Main: render request details + ngayXemPhong
deactivate UI_Detail
UI_Main --> Sale: hien thi thong tin chi tiet yeu cau
deactivate UI_Main
deactivate Sale

== Lap yeu cau moi ==
Sale -> UI_Main: handleOpenCreateRequest()
activate Sale
activate UI_Main
UI_Main -> UI_Create: open()
activate UI_Create

UI_Create -> S_Customer: getCustomers(page, size, search)
activate S_Customer
S_Customer -> DB_Customer: findAll(pageable)
activate DB_Customer
DB_Customer --> S_Customer: findAll(...): Page<KhachHang>
deactivate DB_Customer
S_Customer --> UI_Create: getCustomers(...): ApiListResponse<KhachHang>
deactivate S_Customer

UI_Create --> Sale: render form lap yeu cau moi

Sale -> UI_Create: submitCreateRequest(payload)
UI_Create -> UI_Create: validate()

alt Du lieu khong hop le
  UI_Create -> UI_Main: showToast("Thong tin khong hop le", "error")
  activate UI_Main
  UI_Main --> Sale: showToast("Thong tin khong hop le", "error")
  deactivate UI_Main

else Du lieu hop le
  UI_Create -> S_Request: createRequest(req)
  activate S_Request
  S_Request -> DB_Request: save(entity: YeuCauDangKy)
  activate DB_Request
  DB_Request --> S_Request: save(...): YeuCauDangKy
  deactivate DB_Request
  S_Request --> UI_Create: createRequest(...): YeuCauDangKy
  deactivate S_Request

  UI_Create -> UI_Main: loadRequests(params)
  activate UI_Main
  UI_Main --> UI_Create: render requestTable + statusCards
  deactivate UI_Main

  UI_Create -> UI_Main: showToast("Tao yeu cau thu cong", "success")
  activate UI_Main
  UI_Main --> Sale: showToast("Tao yeu cau thu cong", "success")
  deactivate UI_Main

  UI_Create -> UI_Create: close()
end

deactivate UI_Create
deactivate UI_Main
deactivate Sale

@enduml
@startuml
title Chuc nang Quan ly lich xem phong

hide footbox
autonumber 1
skinparam shadowing false
skinparam sequence {
  ArrowColor #8A2E5D
  LifeLineBorderColor #666666
  LifeLineBackgroundColor #FFFFFF
  ParticipantBorderColor #666666
  ParticipantBackgroundColor #F6F3C9
  ParticipantFontColor #222222
  ActivationBorderColor #8A2E5D
  ActivationBackgroundColor #F9EAF2
}
skinparam ActorBorderColor #8A2E5D
skinparam ActorBackgroundColor #FFFFFF

actor ": Nhan vien Sale" as Sale
boundary ": MHQuanLyLichXemPhong" as UI_Main
boundary ": MHDanhSachYeuCauChoLenLich" as UI_Pending
boundary ": MHLapLichXemPhong" as UI_Create
boundary ": MHChiTietLichHen" as UI_Detail

control ": LichXemPhong" as S_Appointment
control ": YeuCauDangKy" as S_Request
control ": KhachHang" as S_Customer
control ": Phong" as S_Room
control ": NhanVien" as S_Employee

database ": LichXemPhongDB" as DB_Appointment
database ": YeuCauDangKyDB" as DB_Request
database ": KhachHangDB" as DB_Customer
database ": PhongDB" as DB_Room
database ": NhanVienDB" as DB_Employee

== Tai danh sach lich hen ==
Sale -> UI_Main: loadAppointments(params)
activate Sale
activate UI_Main
UI_Main -> S_Appointment: getAppointments(page, size, month, year)
activate S_Appointment
S_Appointment -> DB_Appointment: findByNgayHenBetween(startDate, endDate, pageable)
activate DB_Appointment
DB_Appointment --> S_Appointment: findByNgayHenBetween(...): Page<LichXemPhong>
deactivate DB_Appointment
S_Appointment --> UI_Main: getAppointments(...): ApiListResponse<LichXemPhong>
deactivate S_Appointment
UI_Main --> Sale: render miniCalendar + appointmentList
deactivate UI_Main
deactivate Sale

== Tai danh sach yeu cau cho len lich ==
Sale -> UI_Main: handleTabChange("yeuCauChoLenLich")
activate Sale
activate UI_Main
UI_Main -> UI_Pending: loadPendingRequests(params)
activate UI_Pending
UI_Pending -> S_Request: getRequests(page, size, filters)
activate S_Request
S_Request -> DB_Request: findByFiltersWithSearch(...)
activate DB_Request
DB_Request --> S_Request: findByFiltersWithSearch(...): Page<YeuCauDangKy>
deactivate DB_Request
S_Request -> DB_Request: countByStatus()
activate DB_Request
DB_Request --> S_Request: countByStatus(): List<Object[]>
deactivate DB_Request
S_Request --> UI_Pending: getRequests(...): ApiListResponse<YeuCauDangKy>
deactivate S_Request
UI_Pending --> UI_Main: render requestCards + pagination
deactivate UI_Pending
UI_Main --> Sale: hien thi danh sach yeu cau cho len lich
deactivate UI_Main
deactivate Sale

== Lap lich xem phong moi ==
Sale -> UI_Main: handleOpenRequest(requestId)
activate Sale
activate UI_Main

UI_Main -> S_Request: getRequestById(maYeuCau)
activate S_Request
S_Request -> DB_Request: findById(maYeuCau)
activate DB_Request
DB_Request --> S_Request: findById(...): Optional<YeuCauDangKy>
deactivate DB_Request
S_Request --> UI_Main: getRequestById(...): YeuCauDangKy
deactivate S_Request

UI_Main -> UI_Create: open(yeuCau)
activate UI_Create

UI_Create -> S_Customer: getCustomers(page, size, search)
activate S_Customer
S_Customer -> DB_Customer: findAll(pageable)
activate DB_Customer
DB_Customer --> S_Customer: findAll(...): Page<KhachHang>
deactivate DB_Customer
S_Customer --> UI_Create: getCustomers(...): ApiListResponse<KhachHang>
deactivate S_Customer

UI_Create -> S_Room: getRooms(page, size, search)
activate S_Room
S_Room -> DB_Room: findAll(pageable)
activate DB_Room
DB_Room --> S_Room: findAll(...): Page<Phong>
deactivate DB_Room
S_Room --> UI_Create: getRooms(...): ApiListResponse<Phong>
deactivate S_Room

UI_Create -> S_Employee: getEmployees(page, size, search)
activate S_Employee
S_Employee -> DB_Employee: findAll(pageable)
activate DB_Employee
DB_Employee --> S_Employee: findAll(...): Page<NhanVien>
deactivate DB_Employee
S_Employee --> UI_Create: getEmployees(...): ApiListResponse<NhanVien>
deactivate S_Employee

UI_Create --> Sale: render form lap lich
deactivate UI_Main

Sale -> UI_Create: submitCreateAppointment(payload)

UI_Create -> UI_Create: validate()

alt Du lieu hop le
  UI_Create -> S_Appointment: createAppointment(req)
  activate S_Appointment
  S_Appointment -> DB_Appointment: save(entity: LichXemPhong)
  activate DB_Appointment
  DB_Appointment --> S_Appointment: save(...): LichXemPhong
  deactivate DB_Appointment
  S_Appointment --> UI_Create: createAppointment(...): LichXemPhong
  deactivate S_Appointment

  UI_Create -> UI_Main: loadAppointments(params)
  activate UI_Main
  UI_Main --> UI_Create: render miniCalendar + appointmentList
  deactivate UI_Main

  UI_Create -> UI_Main: showToast("Lap lich thanh cong", "success")
  activate UI_Main
  UI_Main --> Sale: showToast("Lap lich thanh cong", "success")
  deactivate UI_Main

  UI_Create -> UI_Create: close()

else Du lieu khong hop le
  UI_Create -> UI_Main: showToast("Thong tin khong hop le", "error")
  activate UI_Main
  UI_Main --> Sale: showToast("Thong tin khong hop le", "error")
  deactivate UI_Main
end

deactivate UI_Create
deactivate Sale

== Xem chi tiet lich hen ==
Sale -> UI_Main: handleOpenAppointment(maLichHen)
activate Sale
activate UI_Main
UI_Main -> S_Appointment: getAppointmentById(maLichHen)
activate S_Appointment
S_Appointment -> DB_Appointment: findById(maLichHen)
activate DB_Appointment
DB_Appointment --> S_Appointment: findById(...): Optional<LichXemPhong>
deactivate DB_Appointment
S_Appointment --> UI_Main: getAppointmentById(...): LichXemPhong
deactivate S_Appointment

UI_Main -> UI_Detail: open(lichHen)
activate UI_Detail
UI_Detail --> UI_Main: render chi tiet lich hen
deactivate UI_Detail
UI_Main --> Sale: hien thi thong tin chi tiet lich hen
deactivate UI_Main
deactivate Sale

== Xoa lich hen ==
Sale -> UI_Main: handleDeleteAppointment(maLichHen)
activate Sale
activate UI_Main

UI_Main -> UI_Detail: deleteAppointment()
activate UI_Detail

UI_Detail -> S_Appointment: deleteAppointment(maLichHen)
activate S_Appointment
S_Appointment -> DB_Appointment: findById(maLichHen)
activate DB_Appointment
DB_Appointment --> S_Appointment: findById(...): Optional<LichXemPhong>
deactivate DB_Appointment
S_Appointment -> DB_Appointment: delete(entity: LichXemPhong)
activate DB_Appointment
DB_Appointment --> S_Appointment: delete(...): Void
deactivate DB_Appointment
S_Appointment --> UI_Detail: deleteAppointment(...): Void
deactivate S_Appointment

UI_Detail -> UI_Detail: close()

UI_Main -> UI_Main: loadAppointments(params)

UI_Main -> UI_Main: showToast("Xoa lich hen thanh cong", "success")
UI_Main --> Sale: showToast("Xoa lich hen thanh cong", "success")
deactivate UI_Detail
deactivate UI_Main
deactivate Sale

@enduml

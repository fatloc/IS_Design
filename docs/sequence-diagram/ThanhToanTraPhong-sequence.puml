@startuml
title Chức năng Thanh toán trả phòng (Thu thêm/Hoàn cọc)

hide footbox
autonumber 1
skinparam shadowing false
skinparam sequence {
  ArrowColor #8A2E5D
  LifeLineBorderColor #666666
  LifeLineBackgroundColor #FFFFFF
  ParticipantBorderColor #666666
  ParticipantBackgroundColor #F6F3C9
  ParticipantFontColor #222222
  ActivationBorderColor #8A2E5D
  ActivationBackgroundColor #F9EAF2
}
skinparam ActorBorderColor #8A2E5D
skinparam ActorBackgroundColor #FFFFFF

actor ": Nhan vien KeToan" as KeToan
boundary ": MHThanhToanTraPhong" as UI_Main
boundary ": MHBienBanThanhToanTraPhong" as UI_Modal

control ": HopDongThue" as S_Contract
control ": HoSoDatCoc" as S_Deposit
control ": KhachHang" as S_Customer
control ": BangDoiSoat" as S_Settlement
control ": PhieuThanhToan" as S_Payment

database ": HopDongThueDB" as DB_Contract
database ": HoSoDatCocDB" as DB_Deposit
database ": KhachHangDB" as DB_Customer
database ": BangDoiSoatDB" as DB_Settlement
database ": PhieuThanhToanDB" as DB_Payment

== Tai danh sach hop dong cho thanh toan tra phong ==
KeToan -> UI_Main: loadSettlementContracts(params)
activate KeToan
activate UI_Main
UI_Main -> S_Contract: getSettlementContracts(status, page, size)
activate S_Contract
S_Contract -> DB_Contract: findByTrangThaiThanhLy(trangThai)
activate DB_Contract
DB_Contract --> S_Contract: findByTrangThaiThanhLy(...): List<HopDongThue>
deactivate DB_Contract
S_Contract --> UI_Main: getSettlementContracts(...): List<Map>
deactivate S_Contract
UI_Main --> KeToan: render contractTable + pagination
deactivate UI_Main
deactivate KeToan

== Mo bien ban thanh toan tra phong ==
KeToan -> UI_Main: handleOpenPaymentModal(maHopDong)
activate KeToan
activate UI_Main
UI_Main -> S_Contract: getContractById(maHopDong)
activate S_Contract
S_Contract -> DB_Contract: findById(maVanBan)
activate DB_Contract
DB_Contract --> S_Contract: findById(...): HopDongThue
deactivate DB_Contract
S_Contract --> UI_Main: getContractById(...): HopDongThue
deactivate S_Contract

UI_Main -> UI_Modal: open(contract)
activate UI_Modal

UI_Modal -> S_Customer: getCustomerById(maKhachHang)
activate S_Customer
S_Customer -> DB_Customer: findById(maKhachHang)
activate DB_Customer
DB_Customer --> S_Customer: findById(...): KhachHang
deactivate DB_Customer
S_Customer --> UI_Modal: getCustomerById(...): KhachHang
deactivate S_Customer

UI_Modal -> S_Deposit: findByKhachHangSoHuu(maKhachHang)
activate S_Deposit
S_Deposit -> DB_Deposit: findByKhachHangSoHuu(maKhachHang)
activate DB_Deposit
DB_Deposit --> S_Deposit: findByKhachHangSoHuu(...): HoSoDatCoc
deactivate DB_Deposit
S_Deposit --> UI_Modal: findByKhachHangSoHuu(...): HoSoDatCoc
deactivate S_Deposit

UI_Modal -> S_Settlement: getPendingPayments()
activate S_Settlement
S_Settlement -> DB_Settlement: findByTrangThai(trangThai)
activate DB_Settlement
DB_Settlement --> S_Settlement: findByTrangThai(...): List<BangDoiSoat>
deactivate DB_Settlement
S_Settlement --> UI_Modal: getPendingPayments(...): List<BangDoiSoat>
deactivate S_Settlement

UI_Modal -> S_Payment: findByLoaiGiaoDichAndTrangThai(loai, trangThai, pageable)
activate S_Payment
S_Payment -> DB_Payment: findByLoaiGiaoDichAndTrangThai(loai, trangThai, pageable)
activate DB_Payment
DB_Payment --> S_Payment: findByLoaiGiaoDichAndTrangThai(...): Page<PhieuThanhToan>
deactivate DB_Payment
S_Payment --> UI_Modal: findByLoaiGiaoDichAndTrangThai(...): Page<PhieuThanhToan>
deactivate S_Payment

UI_Modal -> UI_Modal: calculateNetAmount()
UI_Modal --> UI_Main: render paymentForm + settlementSummary
deactivate UI_Modal
UI_Main --> KeToan: hien thi bien ban thanh toan tra phong
deactivate UI_Main
deactivate KeToan

== Xac nhan thanh toan tra phong ==
KeToan -> UI_Modal: submitPaymentSettlement(payload)
activate KeToan
activate UI_Modal
UI_Modal -> UI_Modal: validate()

alt Du lieu hop le
  UI_Modal -> S_Settlement: reconcile(request)
  activate S_Settlement
  S_Settlement -> DB_Settlement: save(entity: BangDoiSoat)
  activate DB_Settlement
  DB_Settlement --> S_Settlement: BangDoiSoat
  deactivate DB_Settlement

  UI_Modal -> S_Payment: createPayment(payment)
  activate S_Payment
  S_Payment -> DB_Payment: save(entity: PhieuThanhToan)
  activate DB_Payment
  DB_Payment --> S_Payment: PhieuThanhToan
  deactivate DB_Payment
  S_Payment --> UI_Modal: createPayment(...): PhieuThanhToan
  deactivate S_Payment

  UI_Modal -> S_Contract: updateSettlementStatus(maHopDong, trangThai)
  activate S_Contract
  S_Contract -> DB_Contract: update(maVanBan, entity: HopDongThue)
  activate DB_Contract
  DB_Contract --> S_Contract: update(...): HopDongThue
  deactivate DB_Contract
  S_Contract --> UI_Modal: updateSettlementStatus(...): HopDongThue
  deactivate S_Contract

  UI_Modal -> UI_Main: loadSettlementContracts(params)
  activate UI_Main
  UI_Main --> UI_Modal: render contractTable + pagination
  deactivate UI_Main

  UI_Modal -> UI_Main: showToast("Thanh toan tra phong thanh cong", "success")
  activate UI_Main
  UI_Main --> KeToan: showToast("Thanh toan tra phong thanh cong", "success")
  deactivate UI_Main

  UI_Modal -> UI_Modal: close()

else Du lieu khong hop le
  UI_Modal -> UI_Main: showToast("Thong tin khong hop le", "error")
  activate UI_Main
  UI_Main --> KeToan: showToast("Thong tin khong hop le", "error")
  deactivate UI_Main
end

deactivate UI_Modal
deactivate KeToan

== Huy thao tac thanh toan tra phong ==
KeToan -> UI_Modal: handleCancel()
activate KeToan
activate UI_Modal
UI_Modal -> UI_Modal: close()
UI_Modal --> UI_Main: quay lai man danh sach
deactivate UI_Modal
UI_Main --> KeToan: tiep tuc xem danh sach hop dong
deactivate UI_Main
deactivate KeToan

@enduml
@startuml
title Chức năng Quản lý tài khoản người dùng

hide circle
skinparam shadowing false
skinparam classAttributeIconSize 0

skinparam class {
	BorderColor #4C6E8B
	BackgroundColor #E6F2FF
	FontColor #222222
}

skinparam package {
	BorderColor #888888
	FontColor #333333
	FontSize 14
	Style rectangle
}

' ================= TẦNG GIAO DIỆN =================
package "Tầng Giao Diện" as UI_Layer {
class MHQuanLyTaiKhoanNguoiDung {
	' Presentation (Settings.tsx - StaffTab)
	-searchInput: SearchBox
	-roleFilter: Dropdown
	-staffTable: Grid
	-pagination: Pagination
	-btnReload: Button
	-btnThemTaiKhoan: Button
	-btnCapNhatQuyen: Button
	-btnTamDung: Button
	--
	+loadUsers(page: int, size: int): Promise<void>
	+handleSearch(keyword: String): Void
	+handleFilterRole(role: String): Void
	+handleOpenCreateModal(): Void
	+handleOpenEditModal(maNhanVien: String): Void
	+handleOpenLockModal(maNhanVien: String): Void
	+handleToggleStatus(maNhanVien: String): Void
	+reload(): Void
}

class MHThemTaiKhoanNhanSu {
	' Modal tạo tài khoản
	-hoTenInput: TextBox
	-tenDangNhapInput: TextBox
	-matKhauTamInput: TextBox
	-soDienThoaiInput: TextBox
	-emailInput: TextBox
	-loaiNhanVienDropdown: Dropdown
	-btnLuu: Button
	-btnHuy: Button
	--
	+handleInputChange(field: String, value: Any): Void
	+handleCreateUser(payload: CreateUserRequest): Promise<void>
	+validateForm(): Boolean
	+showDuplicateUsernameError(): Void
}

class MHCapNhatTaiKhoan {
	' Modal cập nhật quyền/thông tin tài khoản
	-hoTenInput: TextBox
	-tenDangNhapInput: TextBox
	-soDienThoaiInput: TextBox
	-emailInput: TextBox
	-loaiNhanVienDropdown: Dropdown
	-btnLuu: Button
	-btnHuy: Button
	--
	+loadUser(maNhanVien: String): Promise<void>
	+handleInputChange(field: String, value: Any): Void
	+handleUpdateUser(maNhanVien: String, payload: UpdateUserRequest): Promise<void>
	+validateForm(): Boolean
	+showDuplicateUsernameError(): Void
}

class MHTamDungTaiKhoan {
	' Modal xác nhận tạm dừng/khóa truy cập
	-warningText: Label
	-btnXacNhan: Button
	-btnHuy: Button
	--
	+handleConfirmAction(maNhanVien: String): Promise<void>
	+handleCancel(): Void
	+showPermissionError(): Void
}
}

' ================= TẦNG NGHIỆP VỤ =================
package "Tầng Nghiệp Vụ" as BLL_Layer {

class NhanVien {
	' Entity + Service (NhanVien + UserService)
	-maNhanVien: String
	-hoTen: String
	-soDienThoai: String
	-email: String
	-tenDangNhap: String
	-phai: String
	-cccd: String
	-loaiNhanVien: String
	-matKhau: String
	--
	+getUsers(page: int, size: int): Page<NhanVien>
	+getUserById(maNhanVien: String): NhanVien
	+createUser(request: CreateUserRequest): NhanVien
	+updateUser(maNhanVien: String, request: UpdateUserRequest): NhanVien
	+deleteUser(maNhanVien: String): Void
	+generateUniqueUsername(email: String, fallbackId: String): String
	+validateTenDangNhap(tenDangNhap: String): Boolean
	+validateAdminPermission(currentRole: String): Boolean
	+findAll(pageable: Pageable): Page<NhanVien>
	+save(entity: NhanVien): NhanVien
	+delete(entity: NhanVien): Void
}
}

' ================= TẦNG TRUY CẬP DỮ LIỆU =================
package "Tầng Truy Cập Dữ Liệu" as DAL_Layer {

class NhanVienDB {
	' Repository (NhanVienRepository)
	--
	+findById(maNhanVien: String): NhanVien
	+findAll(pageable: Pageable): Page<NhanVien>
	+findByEmail(email: String): NhanVien
	+findByTenDangNhap(tenDangNhap: String): NhanVien
	+existsByEmail(email: String): Boolean
	+existsByTenDangNhap(tenDangNhap: String): Boolean
	+save(entity: NhanVien): NhanVien
	+delete(entity: NhanVien): Void
}
}

' ================= RELATIONSHIPS =================
' (Tầng Giao Diện -> Tầng Nghiệp Vụ)
MHQuanLyTaiKhoanNguoiDung o-- NhanVien
MHThemTaiKhoanNhanSu o-- NhanVien
MHCapNhatTaiKhoan o-- NhanVien
MHTamDungTaiKhoan o-- NhanVien

' (Điều hướng mở modal)
MHQuanLyTaiKhoanNguoiDung o-- MHThemTaiKhoanNhanSu
MHQuanLyTaiKhoanNguoiDung o-- MHCapNhatTaiKhoan 
MHQuanLyTaiKhoanNguoiDung o-- MHTamDungTaiKhoan

' (Tầng Nghiệp Vụ -> Tầng Truy Cập Dữ Liệu)
NhanVien o-- NhanVienDB
@enduml
